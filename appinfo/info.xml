<?xml version="1.0"?>
<info>
	<id>expense-report</id>
	<name>Expense Report</name>
	<summary>Render yearly expense report in Nextcloud UI</summary>
	<description>
	<![CDATA[External app that renders an interactive expense report page from Nextcloud Tables data.]]>
	</description>
	<version>1.0.0</version>
	<licence>MIT</licence>
	<author>Yariv Matia</author>
	<namespace>PyAppV2_expense_report</namespace>
	<category>tools</category>
	<bugs>https://github.com/ymatia/expense_report/issues</bugs>
	<dependencies>
		<nextcloud min-version="31" max-version="35"/>
	</dependencies>
	<navigations>
		<navigation role="all">
			<id>expense-report</id>
			<name>Expense Report</name>
			<route>report</route>
			<order>0</order>
			<icon>app.svg</icon>
			<type>link</type>
		</navigation>
    </navigations>
	<external-app>
		<docker-install>
			<registry>ghcr.io</registry>
			<image>ymatia/expense-report</image>
			<image-tag>latest</image-tag>
		</docker-install>
		<environment-variables>
			<variable>
				<name>NC_FACTS_TABLE_ID</name>
				<display-name>Facts table ID</display-name>
				<description>Nextcloud Tables table id for expenses.</description>
				<default>6</default>
			</variable>
			<variable>
				<name>NC_DEBTS_TABLE_ID</name>
				<display-name>Debts table ID</display-name>
				<description>Nextcloud Tables table id for debts.</description>
				<default>10</default>
			</variable>
		</environment-variables>
		<routes>
			<route>
				<url>^/$</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
			</route>
			<route>
				<url>^/report$</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
			</route>
			<route>
				<url>^/data$</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
			</route>
			<route>
				<url>^/health$</url>
				<verb>GET</verb>
				<access_level>PUBLIC</access_level>
			</route>
			<route>
				<url>img\/.*</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
				<headers_to_exclude>[]</headers_to_exclude>
			</route>
			<route>
				<url>js\/.*</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
				<headers_to_exclude>[]</headers_to_exclude>
			</route>
			<route>
				<url>css\/.*</url>
				<verb>GET</verb>
				<access_level>USER</access_level>
				<headers_to_exclude>[]</headers_to_exclude>
			</route>
			<route>
				<url>api\/.*</url>
				<verb>GET,POST,PUT,DELETE</verb>
				<access_level>USER</access_level>
				<headers_to_exclude>[]</headers_to_exclude>
			</route>
		</routes>
	</external-app>
</info>
